SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=SUA_CHAVE_ANON_PUBLIC

# Senha do administrador local (modo offline sem Supabase).
# Obrigatória para habilitar o login local em localhost.
# NÃO use em produção — em produção use sempre o Supabase.
LOCAL_ADMIN_PASSWORD=escolha-uma-senha-forte-aqui

# Contato comercial/suporte exibido no app.
# Use apenas números no WhatsApp, com DDI e DDD. Ex.: 5582999999999
SUPPORT_WHATSAPP_NUMBER=5582999999999
SUPPORT_EMAIL=suporte@seudominio.com.br
TRIAL_DAYS=14
PLAN_PRICE=39
PIX_KEY=sua-chave-pix
PIX_RECEIVER=Seu Nome ou Empresa

# Variáveis privadas para endpoints server-side na Vercel.
# Nunca coloque estas chaves em HTML, app.js, config.example.js com valores reais ou no navegador.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
ADMIN_TOKEN=crie-um-token-longo-para-o-admin
BACKUP_BUCKET=backups
CRON_SECRET=crie-um-token-longo-para-o-cron
# Alternativa específica para o backup, se preferir separar de outros crons:
# BACKUP_CRON_SECRET=crie-um-token-longo-para-o-backup

# Também aceitos pela aplicação:
# NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_PUBLIC
# VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
# VITE_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_PUBLIC
