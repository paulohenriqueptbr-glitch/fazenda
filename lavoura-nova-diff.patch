+// ─── Crop Plot select (popula lavouras existentes + opção "Nova lavoura") ──
+export const populateCropPlotOptions = () => {
+  const select = el.cropPlot;
+  if (!select) return;
+  const currentValue = select.value;
+  const plots = [...new Set(state.cropEvents.map((r) => r.plot_name).filter(Boolean))]
+    .sort((a, b) => a.localeCompare(b, "pt-BR"));
+  select.innerHTML = `
+    <option value="">Selecione...</option>
+    <option value="__new__">&#10133; Nova lavoura...</option>
+    ${plots.map((p) => `<option value="${escapeHtml(p)}">${escapeHtml(p)}</option>`).join("")}
+  `;
+  if (currentValue && (currentValue === "__new__" || plots.includes(currentValue))) {
+    select.value = currentValue;
+  }
+};
