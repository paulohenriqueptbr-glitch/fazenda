{
  "name": "terrasyn",
  "version": "2.0.0",
  "description": "Sistema PWA de gerenciamento de fazenda leiteira",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "vite",
    "build": "node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "fazenda",
    "leite",
    "PWA",
    "offline-first"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "Paulo Henriques",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.28.1",
    "jest": "^29.7.0",
    "vite": "^8.1.0"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.28.1",
    "@esbuild/win32-x64": "^0.28.1"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "app.test.js"
    ],
    "testMatch": [
      "**/*.test.js"
    ]
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2"
  }
}
