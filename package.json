{
  "name": "terrasyn",
  "version": "2.0.0",
  "description": "Sistema PWA de gerenciamento de fazenda leiteira",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "fazenda",
    "leite",
    "PWA",
    "offline-first"
  ],
  "author": "Paulo Henriques",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "app.test.js"
    ],
    "testMatch": [
      "**/*.test.js"
    ]
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2"
  }
}
